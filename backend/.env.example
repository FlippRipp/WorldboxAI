# Copy this file to backend/.env and fill in the values you need.
# At least one provider's API key is required for live LLM calls.

# ---- Google Gemini ----
GEMINI_API_KEY=

# ---- OpenRouter (supports many models via one API key) ----
OPENROUTER_API_KEY=

# ---- OpenAI ----
OPENAI_API_KEY=

# ---- Anthropic Claude ----
ANTHROPIC_API_KEY=

# Models and retry behavior are configured in the app's provider settings UI,
# not here. (Older versions of this file listed STORYTELLER_MODEL /
# READER_MODEL / MODULE_FAST_MODEL overrides — those are no longer honored;
# remove them from your backend/.env if present.)

# ---- LLM mode (mock = deterministic, no API calls) ----
LLM_MODE=live

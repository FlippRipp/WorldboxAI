# Copy this file to backend/.env and fill in the values you need.
# At least one provider's API key is required for live LLM calls.

# ---- Google Gemini ----
GEMINI_API_KEY=

# ---- OpenRouter (supports many models via one API key) ----
OPENROUTER_API_KEY=

# ---- OpenAI ----
OPENAI_API_KEY=

# ---- Anthropic Claude ----
ANTHROPIC_API_KEY=

# ---- Model overrides (LiteLLM model strings) ----
# These can also be configured from the Model Settings UI.
STORYTELLER_MODEL=gemini/gemini-2.5-flash
STORYTELLER_FALLBACK_MODELS=
READER_MODEL=gemini/gemini-2.5-flash
EMBEDDING_MODEL=gemini/gemini-embedding-2
MODULE_FAST_MODEL=gemini/gemini-2.5-flash

# ---- Retry ----
LLM_PROVIDER_RETRY_ATTEMPTS=2
LLM_PROVIDER_RETRY_DELAY_SECONDS=1

# ---- LLM mode (mock = deterministic, no API calls) ----
LLM_MODE=live

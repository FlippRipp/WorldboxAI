# Python
__pycache__/
*.py[cod]
*.egg-info/
.eggs/
dist/
build/

# Virtual environment
venv/

# Backend secrets and runtime
backend/.env
backend_output.log
.backend_pid.tmp
server.log
server_err.log

# Provider configs contain API keys — commit config.example.json instead
data/providers/*/config.json

# Frontend
frontend/node_modules/
frontend/dist/

# IDE
.vscode/
.idea/

# OS
Thumbs.db
.DS_Store

# User data (characters, worlds, scenarios, saves, theme)
data/saves/
data/characters/
data/worlds/
data/scenarios/
data/theme.json

# Image generation runtime data (API key, image index, downloaded images)
data/wb_image_gen/

# Local SD WebUI installed by modules/wb_image_gen/image_server.sh|.bat
image_server/

